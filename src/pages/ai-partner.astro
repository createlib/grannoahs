---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="AIデジタル相棒 | GRAN NOAHS">
  <Header slot="header" />
  
  <div class="page-content active fade-in">
    <div class="pt-16 sm:pt-24 md:pt-32 pb-16 md:pb-24 text-center px-6 relative">
      <div class="inline-flex items-center justify-center w-16 h-16 md:w-28 md:h-28 rounded-2xl md:rounded-[2rem] bg-gradient-to-br from-indigo-500 to-pink-500 shadow-xl md:shadow-2xl shadow-pink-500/20 mb-6 md:mb-10 transform hover:rotate-12 transition-transform duration-500">
        <i data-lucide="bot" class="text-white" style="width: 32px; height: 32px;"></i>
      </div>
      <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-[7rem] font-extrabold tracking-tighter text-slate-900 mb-6 md:mb-10 leading-tight">
        あなただけの、<br class="md:hidden" />進化する<span class="gradient-text">「デジタル相棒」</span>
      </h1>
      <p class="text-base sm:text-xl md:text-2xl xl:text-3xl text-slate-600 max-w-4xl mx-auto font-medium leading-relaxed">
        人格DNAと環境DNAの高度なシミュレーションが、<br class="hidden md:block"/>
        単なるAIを超えた、頼れる相棒を生み出します。
      </p>
    </div>

    <!-- Feature 1 -->
    <div class="w-[92%] xl:w-[88%] max-w-[1920px] mx-auto pb-20 md:pb-40">
      <div class="glass-card rounded-[2rem] md:rounded-[4rem] p-8 md:p-12 lg:p-24 flex flex-col lg:flex-row items-center gap-10 md:gap-20 relative overflow-hidden group">
        <div class="absolute top-[-20%] right-[-10%] w-[50%] h-[100%] bg-gradient-to-l from-indigo-200/50 to-transparent blur-3xl z-0 transform group-hover:scale-110 transition-transform duration-1000"></div>
        
        <div class="w-full lg:w-1/2 order-2 lg:order-1 relative z-10">
          <div class="inline-flex items-center gap-2 md:gap-3 px-4 py-2 md:px-6 md:py-3 rounded-full bg-indigo-100 text-indigo-700 text-sm md:text-lg font-bold mb-6 md:mb-8">
            <i data-lucide="fingerprint" style="width: 16px; height: 16px;"></i> Core Technology
          </div>
          <h2 class="text-2xl sm:text-4xl lg:text-6xl font-extrabold text-slate-900 mb-6 md:mb-8 tracking-tight leading-tight">「人格DNA」と<br/>「環境DNA」</h2>
          <p class="text-slate-600 text-sm sm:text-base md:text-xl xl:text-2xl leading-relaxed mb-6 md:mb-8 font-medium">
            ユーザー個人の特性や価値観を構成する<strong>「人格DNA」</strong>と、周囲の状況や組織文化を表す<strong>「環境DNA」</strong>を精緻に構築します。
          </p>
          <p class="text-slate-600 text-sm sm:text-base md:text-xl xl:text-2xl leading-relaxed font-medium">
            これらを掛け合わせることで、特定の環境下で人格アバターがどう考え、どう行動するかを高精度にシミュレーション。採用時のミスマッチを防ぎ、最適なコミュニケーションの土台を作ります。
          </p>
        </div>
        
        <div class="w-full lg:w-1/2 order-1 lg:order-2 flex justify-center relative z-10">
          <div class="w-full max-w-sm md:max-w-2xl aspect-square rounded-[2rem] md:rounded-[3rem] bg-white border border-white/50 shadow-[0_10px_30px_rgba(0,0,0,0.05)] flex flex-col items-center justify-center p-6 md:p-10 text-center relative overflow-hidden group-hover:shadow-[0_20px_50px_rgba(79,70,229,0.15)] transition-shadow duration-500">
             <div class="absolute inset-0 bg-gradient-to-br from-indigo-50 to-pink-50 opacity-50"></div>
             <div class="relative z-10 w-32 h-32 md:w-64 md:h-64 rounded-full bg-gradient-to-tr from-indigo-200 to-pink-200 blur-2xl animate-pulse flex items-center justify-center"></div>
             <i data-lucide="fingerprint" class="text-indigo-500 absolute z-20 drop-shadow-xl" stroke-width="1" style="width: 80px; height: 80px;"></i>
             <span class="text-xs md:text-lg font-bold text-slate-400 absolute bottom-6 md:bottom-12 z-20 bg-white/80 px-4 md:px-8 py-2 md:py-4 rounded-full backdrop-blur-sm shadow-sm">[ Simulation Engine Active ]</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Feature 2 -->
    <div class="w-[92%] xl:w-[88%] max-w-[1920px] mx-auto pb-20 md:pb-40">
      <div class="flex flex-col lg:flex-row items-center gap-10 md:gap-20">
        <div class="w-full lg:w-1/2 flex justify-center">
          <div class="w-full max-w-sm md:max-w-2xl aspect-square rounded-[2rem] md:rounded-[4rem] bg-gradient-to-br from-purple-500 to-indigo-600 p-1 md:p-1.5 shadow-[0_20px_40px_rgba(99,102,241,0.25)] hover:scale-105 transition-transform duration-500">
            <div class="w-full h-full bg-slate-900 rounded-[1.8rem] md:rounded-[3.8rem] flex flex-col items-center justify-center p-6 md:p-12 text-center relative overflow-hidden">
               <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjEiIGZpbGw9IiNmZmYiIG9wYWNpdHk9IjAuMDUiLz48L3N2Zz4=')]"></div>
               <i data-lucide="message-square-share" class="text-purple-400 mb-6 md:mb-10 drop-shadow-[0_0_15px_rgba(168,85,247,0.6)] animate-bounce" stroke-width="1" style="width: 80px; height: 80px; animation-duration: 3s;"></i>
               <span class="text-xs md:text-lg font-bold text-white/70 bg-white/10 px-4 md:px-8 py-2 md:py-4 rounded-full backdrop-blur-md border border-white/10">[ Partner-to-Partner Network ]</span>
            </div>
          </div>
        </div>
        <div class="w-full lg:w-1/2">
          <h2 class="text-2xl sm:text-4xl lg:text-6xl font-extrabold text-slate-900 mb-6 md:mb-10 tracking-tight leading-tight">対話、そして<br/>他者の相棒へ</h2>
          <p class="text-slate-600 text-sm sm:text-base md:text-xl xl:text-2xl leading-relaxed mb-6 md:mb-10 font-medium">
            構築されたAIは、何でも話せる「相棒」として日常的に対話できます。
          </p>
          <div class="bg-indigo-50/50 backdrop-blur-md border border-indigo-100/50 rounded-2xl md:rounded-3xl p-6 md:p-10 my-6 md:my-10 shadow-sm transform hover:-translate-y-2 transition-transform">
            <p class="text-slate-800 text-lg sm:text-2xl xl:text-3xl font-bold leading-relaxed">
              画期的なのは、<br/><span class="text-indigo-600 text-xl sm:text-3xl xl:text-4xl mt-1 md:mt-2 block">自分以外の「誰かの相棒」とも会話ができる</span>点です。
            </p>
          </div>
          <p class="text-slate-600 text-sm sm:text-base md:text-xl xl:text-2xl leading-relaxed font-medium">
            直接言いづらいことのニュアンスを探ったり、趣味の合う人を探すための事前コミュニケーションなど、AIを介した新しい人間関係の構築をサポートします。
          </p>
        </div>
      </div>
    </div>

    <!-- Feature 3 -->
    <div class="py-20 md:py-40 relative">
      <div class="absolute inset-0 bg-white/40 backdrop-blur-3xl border-y border-white/50 z-0"></div>
      <div class="w-[92%] xl:w-[88%] max-w-[1920px] mx-auto relative z-10">
        <div class="text-center mb-12 md:mb-24">
          <h2 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-extrabold text-slate-900 mb-4 md:mb-8 tracking-tight">自律的なアクション</h2>
          <p class="text-slate-600 text-sm sm:text-base md:text-2xl xl:text-3xl font-medium max-w-4xl mx-auto leading-relaxed">相棒はバックグラウンドで働き、あなたの日常をスマートにサポートします。</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 xl:gap-16">
          <div class="glass-card rounded-[2rem] md:rounded-[3.5rem] p-8 md:p-12 lg:p-20 hover-lift relative overflow-hidden group min-h-[300px] md:min-h-[500px]">
            <div class="absolute top-0 right-0 w-40 h-40 md:w-64 md:h-64 bg-pink-300/20 rounded-full blur-3xl group-hover:bg-pink-400/30 transition-colors duration-500"></div>
            <div class="w-16 h-16 md:w-24 md:h-24 rounded-xl md:rounded-[2rem] bg-gradient-to-br from-pink-400 to-rose-500 flex items-center justify-center mb-6 md:mb-10 shadow-xl shadow-pink-500/30 group-hover:scale-110 transition-transform">
              <i data-lucide="calendar-sync" class="text-white" style="width: 32px; height: 32px;"></i>
            </div>
            <h3 class="text-xl sm:text-2xl md:text-4xl font-extrabold text-slate-900 mb-4 md:mb-8">スケジュール調整と依頼</h3>
            <p class="text-slate-600 leading-relaxed text-sm sm:text-base md:text-xl xl:text-2xl font-medium">
              相棒同士が連携し、面倒な日程調整や業務の依頼・すり合わせをユーザーの代わりに行ってくれます。
            </p>
          </div>

          <div class="glass-card rounded-[2rem] md:rounded-[3.5rem] p-8 md:p-12 lg:p-20 hover-lift relative overflow-hidden group min-h-[300px] md:min-h-[500px]">
             <div class="absolute top-0 right-0 w-40 h-40 md:w-64 md:h-64 bg-purple-300/20 rounded-full blur-3xl group-hover:bg-purple-400/30 transition-colors duration-500"></div>
            <div class="w-16 h-16 md:w-24 md:h-24 rounded-xl md:rounded-[2rem] bg-gradient-to-br from-purple-400 to-indigo-500 flex items-center justify-center mb-6 md:mb-10 shadow-xl shadow-purple-500/30 group-hover:scale-110 transition-transform">
              <i data-lucide="book-text" class="text-white" style="width: 32px; height: 32px;"></i>
            </div>
            <h3 class="text-xl sm:text-2xl md:text-4xl font-extrabold text-slate-900 mb-4 md:mb-8">日記での報告と承認</h3>
            <p class="text-slate-600 leading-relaxed text-sm sm:text-base md:text-xl xl:text-2xl font-medium">
              他の相棒と話して決まったことは、毎日の「日記」として報告。重要な決定事項はきちんと「承認」をもらいに来ます。
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Feature 4 CTA -->
    <div class="w-[92%] xl:w-[88%] max-w-[1920px] mx-auto py-20 md:py-40">
      <div class="glass-card-dark rounded-[2rem] md:rounded-[4rem] p-8 md:p-12 lg:p-24 text-center lg:text-left flex flex-col lg:flex-row items-center gap-10 md:gap-20 overflow-hidden relative shadow-[0_20px_50px_rgba(0,0,0,0.3)]">
        <div class="absolute top-[-50%] right-[-20%] w-[80%] h-[150%] bg-gradient-to-bl from-indigo-500/40 via-purple-500/20 to-transparent blur-[120px] z-0 pointer-events-none animate-pulse" style="animation-duration: 4s;"></div>
        
        <div class="w-full lg:w-2/3 relative z-10">
          <span class="inline-block bg-white/10 text-white border border-white/20 px-4 py-1.5 md:px-6 md:py-2 rounded-full font-bold tracking-widest text-xs md:text-base uppercase mb-6 md:mb-8 backdrop-blur-md">Online to Offline</span>
          <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold text-white mb-6 md:mb-10 tracking-tight leading-tight">リアルイベントも、<br/>一緒に。</h2>
          <p class="text-slate-300 text-sm sm:text-base md:text-2xl leading-relaxed mb-8 md:mb-12 max-w-3xl font-medium">
            デジタル空間だけではありません。相棒が提案したオフラインのリアルイベントを一緒に楽しむことが可能。現実の体験がDNAにフィードバックされ、相棒はよりあなたらしく成長します。
          </p>
          <a href="/contact" class="w-full sm:w-auto px-8 md:px-12 py-4 md:py-6 rounded-full bg-white text-slate-900 font-extrabold text-sm md:text-xl hover:bg-slate-100 hover:scale-105 transition-all duration-300 inline-flex items-center justify-center shadow-xl shadow-white/20">
            導入を相談する <i data-lucide="arrow-right" class="ml-2 md:ml-4" style="width: 20px; height: 20px;"></i>
          </a>
        </div>
        <div class="w-full lg:w-1/3 flex justify-center relative z-10">
          <div class="w-40 h-40 md:w-72 md:h-72 rounded-[2rem] md:rounded-[4rem] bg-gradient-to-br from-white/10 to-white/5 border border-white/20 backdrop-blur-xl flex items-center justify-center shadow-2xl transform rotate-6 hover:rotate-0 transition-transform duration-500">
            <i data-lucide="ticket" class="text-white drop-shadow-2xl" stroke-width="1" style="width: 80px; height: 80px;"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <Footer slot="footer" />
</Layout>
