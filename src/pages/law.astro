---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="特定商取引法に基づく表記 | GRAN NOAHS">
  <Header slot="header" />
  
  <div class="page-content active fade-in">
    <div class="pt-16 sm:pt-24 md:pt-32 pb-16 md:pb-24 text-center px-4 relative">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 mb-4 md:mb-6 leading-tight">特定商取引法に基づく表記</h1>
    </div>

    <div class="w-[92%] xl:w-[88%] max-w-[800px] mx-auto pb-20 md:pb-40 text-sm md:text-base text-slate-800">
      <div class="glass-card rounded-[2rem] p-8 md:p-12 mb-10 overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <tbody>
            <tr class="border-b border-slate-200/60">
              <th class="py-4 pr-6 font-bold text-slate-600 w-1/3 align-top">販売業者</th>
              <td class="py-4 font-medium">株式会社 GRAN NOAHS</td>
            </tr>
            <tr class="border-b border-slate-200/60">
              <th class="py-4 pr-6 font-bold text-slate-600 align-top">代表責任者</th>
              <td class="py-4 font-medium">（※登記後に記載）</td>
            </tr>
            <tr class="border-b border-slate-200/60">
              <th class="py-4 pr-6 font-bold text-slate-600 align-top">所在地</th>
              <td class="py-4 font-medium">愛知県名古屋市西区花の木</td>
            </tr>
            <tr class="border-b border-slate-200/60">
              <th class="py-4 pr-6 font-bold text-slate-600 align-top">電話番号</th>
              <td class="py-4 font-medium">（※事業開始に合わせて記載）</td>
            </tr>
            <tr class="border-b border-slate-200/60">
              <th class="py-4 pr-6 font-bold text-slate-600 align-top">メールアドレス</th>
              <td class="py-4 font-medium">（※事業開始に合わせて記載）</td>
            </tr>
            <tr class="border-b border-slate-200/60">
              <th class="py-4 pr-6 font-bold text-slate-600 align-top">提供価格</th>
              <td class="py-4 font-medium leading-relaxed">
                各サービスの紹介ページ、もしくはお見積書にて個別に提示いたします。<br />
                （AIデジタル相棒サービス、SaaaS導入支援、コンサルティング費用等）
              </td>
            </tr>
            <tr class="border-b border-slate-200/60">
              <th class="py-4 pr-6 font-bold text-slate-600 align-top">商品代金以外の必要料金</th>
              <td class="py-4 font-medium leading-relaxed">
                ・消費税<br />
                ・インターネット接続料金、通信料金（お客様負担となります）<br />
                ・銀行振込の場合の振込手数料
              </td>
            </tr>
            <tr class="border-b border-slate-200/60">
              <th class="py-4 pr-6 font-bold text-slate-600 align-top">支払方法および支払の時期</th>
              <td class="py-4 font-medium leading-relaxed">
                支払方法：クレジットカード決済、銀行振込<br />
                支払時期：サービス提供前の事前決済、または各契約書が定める期日
              </td>
            </tr>
            <tr class="border-b border-slate-200/60">
              <th class="py-4 pr-6 font-bold text-slate-600 align-top">役務の提供時期</th>
              <td class="py-4 font-medium leading-relaxed">
                クレジットカード決済、銀行振込の入金確認後、または各契約に定める開始日より速やかにサービスの提供を開始します。
              </td>
            </tr>
            <tr>
              <th class="py-4 pr-6 font-bold text-slate-600 align-top">キャンセル・返金について</th>
              <td class="py-4 font-medium leading-relaxed">
                提供するサービスの性質上（デジタルコンテンツ、コンサルティング役務など）、原則としてサービス提供開始後のキャンセルおよび返金はお受けしておりません。特段の事情がある場合は、契約書の定めに従います。
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  
  <Footer slot="footer" />
</Layout>
