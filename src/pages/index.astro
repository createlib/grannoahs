---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="株式会社GRAN NOAHS コーポレートサイト">
  <Header slot="header" />
  
  <div class="page-content active fade-in">
    <!-- ヒーローセクション -->
    <section class="relative pt-16 sm:pt-24 md:pt-32 pb-24 md:pb-40 xl:pb-48">
      <div class="w-[92%] xl:w-[88%] max-w-[1920px] mx-auto text-center relative z-10 flex flex-col items-center">
        
        <div class="glass-card inline-flex items-center gap-2 px-4 py-2 md:px-6 md:py-3 rounded-full text-xs md:text-base xl:text-lg font-bold text-slate-700 mb-8 md:mb-12 hover:scale-105 transition-transform cursor-default">
          <span class="flex h-2.5 w-2.5 relative">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-pink-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-pink-500"></span>
          </span>
          Next Generation Social Innovation
        </div>
        
        <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-[6.5rem] xl:text-[8rem] font-extrabold tracking-tight text-slate-900 mb-6 md:mb-10 leading-[1.2] md:leading-[1.1]">
          AIと人の行動データで、<br />
          <span class="gradient-text drop-shadow-sm">新しい社会</span>の形を創る。
        </h1>
        
        <p class="text-base sm:text-lg md:text-2xl xl:text-3xl text-slate-600 mb-10 md:mb-16 max-w-5xl mx-auto leading-relaxed font-medium">
          行動経済学とデータサイエンスの力で、地方創生から組織課題まで。<br class="hidden lg:block"/>
          本質的な解決策と<strong class="text-indigo-600">「デジタルな相棒」</strong>を提供します。
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-6 w-full sm:w-auto">
          <a 
            href="/ai-partner"
            class="w-full sm:w-auto px-8 py-4 md:px-12 md:py-6 rounded-full bg-slate-900 text-white font-bold text-sm md:text-xl shadow-[0_10px_30px_rgba(0,0,0,0.15)] hover:shadow-[0_15px_40px_rgba(79,70,229,0.3)] transition-all duration-300 transform hover:-translate-y-1 flex items-center justify-center group overflow-hidden relative"
          >
            <div class="absolute inset-0 h-full w-full bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <span class="relative z-10 flex items-center">
              AIデジタル相棒を見る
              <i data-lucide="arrow-right" class="ml-2 md:ml-3 group-hover:translate-x-2 transition-transform" style="width: 20px; height: 20px;"></i>
            </span>
          </a>
          <a 
            href="/services"
            class="w-full sm:w-auto px-8 py-4 md:px-12 md:py-6 rounded-full glass-card text-slate-900 font-bold text-sm md:text-xl hover:bg-white/80 transition-all duration-300 flex items-center justify-center transform hover:-translate-y-1"
          >
            全事業内容を見る
          </a>
        </div>
      </div>
    </section>

    <!-- 事業概要 -->
    <section class="py-16 md:py-32 relative z-10">
      <div class="w-[92%] xl:w-[88%] max-w-[1920px] mx-auto">
        <div class="mb-10 md:mb-20 flex flex-col md:flex-row md:items-end justify-between gap-4 md:gap-6">
          <div>
            <h2 class="text-3xl sm:text-4xl md:text-6xl xl:text-7xl font-extrabold tracking-tight text-slate-900 mb-3 md:mb-6">Our Businesses</h2>
            <p class="text-slate-600 text-sm sm:text-base md:text-xl xl:text-2xl max-w-3xl font-medium leading-relaxed">4つの事業領域で、人と社会の新しいつながりをデザインします。</p>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8 xl:gap-10">
          <!-- 1. AI事業 -->
          <a 
            href="/ai-partner"
            class="block lg:col-span-2 group relative rounded-[2rem] md:rounded-[3rem] p-8 md:p-12 lg:p-16 hover-lift cursor-pointer overflow-hidden flex flex-col justify-between min-h-[350px] md:min-h-[500px]"
          >
            <div class="absolute inset-0 bg-white/60 backdrop-blur-xl border border-white/80 z-0"></div>
            <div class="absolute right-0 bottom-0 w-[150%] h-[150%] bg-gradient-to-tl from-indigo-100 via-purple-50/50 to-transparent opacity-80 z-0 transform translate-x-1/4 translate-y-1/4 rounded-full group-hover:scale-110 transition-transform duration-700"></div>
            
            <div class="relative z-10 max-w-2xl">
              <div class="w-12 h-12 md:w-20 md:h-20 rounded-xl md:rounded-[2rem] bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center mb-6 md:mb-10 shadow-lg shadow-indigo-500/30 group-hover:rotate-12 transition-transform duration-500">
                <i data-lucide="bot" class="text-white" style="width: 24px; height: 24px;"></i>
              </div>
              <h3 class="text-2xl sm:text-3xl md:text-5xl xl:text-6xl font-extrabold text-slate-900 mb-4 md:mb-6 tracking-tight group-hover:gradient-text transition-all duration-300 leading-tight">
                AIデータを活用した<br/>社会課題解決事業
              </h3>
              <p class="text-slate-600 text-sm sm:text-base md:text-xl xl:text-2xl leading-relaxed mb-6 md:mb-10 font-medium">
                人格DNAと環境DNAを用いたシミュレーションで、あなた専属の「デジタル相棒」を構築。スケジュール調整や日記の報告など、次世代のサポートを提供します。
              </p>
              <div class="inline-flex items-center font-bold text-sm md:text-xl text-indigo-600 bg-indigo-50/50 px-5 py-2.5 md:px-8 md:py-4 rounded-full border border-indigo-100 transition-colors group-hover:bg-indigo-100">
                詳細を見る <i data-lucide="arrow-up-right" class="ml-1 md:ml-2 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" style="width: 18px; height: 18px;"></i>
              </div>
            </div>
            <div class="absolute right-10 bottom-10 w-40 h-40 md:w-64 md:h-64 bg-gradient-to-br from-indigo-400 to-pink-400 rounded-full blur-3xl opacity-20 group-hover:opacity-40 transition-opacity duration-500"></div>
          </a>

          <!-- 2. コミュニティ -->
          <a 
            href="https://noonealonehere.pages.dev/" target="_blank" rel="noopener noreferrer"
            class="block group glass-card rounded-[2rem] md:rounded-[3rem] p-8 md:p-12 lg:p-16 hover-lift cursor-pointer flex flex-col min-h-[300px] md:min-h-[500px] relative overflow-hidden"
          >
            <div class="absolute top-0 right-0 w-32 h-32 md:w-40 md:h-40 bg-orange-400/10 rounded-full blur-2xl z-0 group-hover:scale-150 transition-transform duration-500"></div>
            <div class="relative z-10 flex flex-col h-full">
              <div class="w-12 h-12 md:w-20 md:h-20 rounded-xl md:rounded-[2rem] bg-white border border-slate-100 shadow-sm flex items-center justify-center mb-6 md:mb-8 group-hover:-translate-y-2 transition-transform duration-300">
                <i data-lucide="users" class="text-orange-500" style="width: 24px; height: 24px;"></i>
              </div>
              <h3 class="text-xl sm:text-2xl md:text-3xl xl:text-4xl font-extrabold text-slate-900 mb-4 md:mb-6 tracking-tight">NOAHコミュニティ</h3>
              <p class="text-slate-600 text-sm sm:text-base md:text-xl leading-relaxed mb-6 md:mb-8 flex-grow font-medium">
                多様な人材が集う実践的なコミュニティ。参加者の自己実現を後押しする心理的安全性のある場を提供しています。
              </p>
              <div class="mt-auto inline-flex items-center text-sm md:text-lg font-bold text-orange-600 group-hover:text-orange-700 transition-colors">
                公式サイトへ <i data-lucide="arrow-up-right" class="ml-1 md:ml-2 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" style="width: 16px; height: 16px;"></i>
              </div>
            </div>
          </a>

          <!-- 3. SaaaS -->
          <a 
            href="/services"
            class="block lg:col-span-2 group glass-card-dark rounded-[2rem] md:rounded-[3rem] p-8 md:p-12 lg:p-16 hover-lift cursor-pointer flex flex-col md:flex-row items-start md:items-center justify-between gap-6 md:gap-10 min-h-[300px] md:min-h-[450px] overflow-hidden relative"
          >
            <div class="absolute -left-10 -bottom-10 md:-left-20 md:-bottom-20 w-40 h-40 md:w-80 md:h-80 bg-indigo-600/30 rounded-full blur-3xl z-0 group-hover:scale-150 transition-transform duration-700"></div>
            <div class="relative z-10 max-w-3xl">
              <div class="w-12 h-12 md:w-20 md:h-20 rounded-xl md:rounded-[2rem] bg-white/10 border border-white/20 backdrop-blur-md flex items-center justify-center mb-6 md:mb-8 group-hover:scale-110 transition-transform duration-300">
                <i data-lucide="monitor-check" class="text-indigo-300" style="width: 24px; height: 24px;"></i>
              </div>
              <h3 class="text-2xl sm:text-3xl md:text-4xl md:text-5xl font-extrabold text-white mb-4 md:mb-6 tracking-tight">SaaaS事業</h3>
              <p class="text-slate-300 leading-relaxed text-sm sm:text-base md:text-xl xl:text-2xl font-medium">
                企業や個人の煩雑なバックオフィス業務をデジタル技術で効率化。本来注力すべきコア業務への集中をサポートします。
              </p>
            </div>
            <div class="relative z-10 w-full md:w-auto mt-4 md:mt-0 flex justify-end">
               <div class="inline-flex items-center justify-center w-12 h-12 md:w-24 md:h-24 rounded-full bg-white text-slate-900 group-hover:bg-indigo-500 group-hover:text-white transition-colors duration-300 shadow-xl">
                 <i data-lucide="arrow-up-right" class="group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" style="width: 24px; height: 24px;"></i>
               </div>
            </div>
          </a>

          <!-- 4. 地方創生 -->
          <a 
            href="/services"
            class="block group glass-card rounded-[2rem] md:rounded-[3rem] p-8 md:p-12 lg:p-16 hover-lift cursor-pointer flex flex-col min-h-[300px] md:min-h-[500px] relative overflow-hidden"
          >
            <div class="absolute top-0 right-0 w-32 h-32 md:w-40 md:h-40 bg-emerald-400/10 rounded-full blur-2xl z-0 group-hover:scale-150 transition-transform duration-500"></div>
            <div class="relative z-10 flex flex-col h-full">
              <div class="w-12 h-12 md:w-20 md:h-20 rounded-xl md:rounded-[2rem] bg-white border border-slate-100 shadow-sm flex items-center justify-center mb-6 md:mb-8 group-hover:-translate-y-2 transition-transform duration-300">
                <i data-lucide="leaf" class="text-emerald-500" style="width: 24px; height: 24px;"></i>
              </div>
              <h3 class="text-xl sm:text-2xl md:text-3xl xl:text-4xl font-extrabold text-slate-900 mb-4 md:mb-6 tracking-tight">地方創生事業</h3>
              <p class="text-slate-600 text-sm sm:text-base md:text-xl leading-relaxed mb-6 md:mb-8 flex-grow font-medium">
                古民家などの地域資源を活用した施設設計と、独自のシステム開発。地方に新たな雇用と人の流れを創り出します。
              </p>
              <div class="mt-auto inline-flex items-center text-sm md:text-lg font-bold text-slate-500 group-hover:text-emerald-600 transition-colors">
                詳しく <i data-lucide="arrow-right" class="ml-1 md:ml-2 group-hover:translate-x-1 transition-transform" style="width: 16px; height: 16px;"></i>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>
  </div>
  
  <Footer slot="footer" />
</Layout>
